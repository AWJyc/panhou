# /etc/tradeagent/.env — production environment file
# chmod 640 + chown root:tradeagent  (group-readable, group is tradeagent service user)

# ─── Database ──────────────────────────────────────────────────────────────
# SQLite: simplest, fine for MVP. Note four slashes = absolute path.
DATABASE_URL=sqlite:////var/lib/tradeagent/tradeagent.db
# Postgres example (uncomment if you migrate to Aliyun RDS):
# DATABASE_URL=postgresql+psycopg://tradeagent:STRONGPASS@rds-host.aliyuncs.com:5432/tradeagent

# ─── External APIs ─────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# Server-side LLM provider for the daily report (NOT the user BYOK key).
# Supported: deepseek | anthropic | openai | doubao | qwen | openai_compatible
REPORT_PROVIDER=deepseek
REPORT_API_KEY=sk-...
REPORT_MODEL=deepseek-chat
# Required only for openai_compatible / doubao / custom:
# REPORT_BASE_URL=https://api.deepseek.com

# Optional: Anthropic fallback if REPORT_API_KEY empty
ANTHROPIC_API_KEY=

# ─── Admin ─────────────────────────────────────────────────────────────────
# Token to call POST /api/admin/rebuild — generate with: openssl rand -hex 24
ADMIN_REBUILD_TOKEN=CHANGE_ME_TO_A_RANDOM_STRING

# ─── CORS (browser → backend; nginx already proxies /api so usually empty) ─
# CORS_ORIGINS=https://your.domain.com

# ─── 飞书机器人告警（pipeline 跑完推送成功/失败卡片） ──────────────
# 飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook + 签名 secret
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
NOTIFY_ENABLED=true
# all = 每次都通知；failure = 只在失败时通知
NOTIFY_LEVEL=all
