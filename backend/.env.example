# Copy this to .env and fill in real values. Never commit .env.
# !! 不要把真 key 写在这个文件里 !! 这个文件会进 git 仓库，只能放占位符。

# 数据库（MVP 用 SQLite 文件，上线换 postgresql+psycopg://user:pwd@host/db）
DATABASE_URL=sqlite:///./tradeagent.db

# Tavily 搜索 key（去 https://tavily.com 申请）
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 服务端默认报告生成 LLM
# REPORT_PROVIDER: anthropic | deepseek | doubao | qwen | openai | openai_compatible
REPORT_PROVIDER=deepseek
REPORT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# REPORT_MODEL 留空走 provider 默认（deepseek=deepseek-chat / qwen=qwen-plus 等）
REPORT_MODEL=
# REPORT_BASE_URL 留空走 provider 默认；自托管或新厂商时填
REPORT_BASE_URL=

# 兼容字段：如果 REPORT_PROVIDER=anthropic 时可用此 key（也可直接放进 REPORT_API_KEY）
ANTHROPIC_API_KEY=

# 手动 rebuild 接口的保护 token（随便填一个随机串）
ADMIN_REBUILD_TOKEN=change-me-to-a-random-string

# CORS 允许的前端来源（开发期）
CORS_ORIGINS=["http://localhost:3000"]

# 调度器时区
SCHEDULER_TIMEZONE=Asia/Shanghai

# === 用户/BYOK 加密 ===
# AUTH_SECRET：openssl rand -hex 32
AUTH_SECRET=
AUTH_TOKEN_TTL_DAYS=30
# BYOK_ENCRYPTION_KEY：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=
# 开发期 false（HTTP）；上 HTTPS 后改 true
COOKIE_SECURE=false

# === 飞书自定义机器人告警 ===
# 飞书群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 webhook 地址
FEISHU_WEBHOOK_URL=
# 飞书机器人安全设置开"签名校验"才需要；否则留空
FEISHU_WEBHOOK_SECRET=
# 总开关
NOTIFY_ENABLED=true
# all = 每次都通知；failure = 只通知失败
NOTIFY_LEVEL=all
